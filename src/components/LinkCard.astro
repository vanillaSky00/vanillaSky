---
interface Props {
  url: string;
  title: string;
  description?: string;
  image?: string;
}

const { url, title, description, image } = Astro.props;
const domain = new URL(url).hostname.replace('www.', '');
---

<a href={url} class="link-card" target="_blank" rel="noopener">
  {image && <img src={image} alt={title} class="link-card__image" />}
  <div class="link-card__body">
    <span class="link-card__domain label">{domain}</span>
    <span class="link-card__title">{title}</span>
    {description && <span class="link-card__desc">{description}</span>}
  </div>
  <span class="link-card__arrow" aria-hidden="true">↗</span>
</a>

<style>
.link-card {
  display: flex;
  align-items: center;
  gap: 1rem;
  border: 1px solid var(--border-strong);
  border-radius: 4px;
  padding: 0.9rem 1.1rem;
  margin-block: 1.5em;
  transition: border-color 0.2s, background 0.2s;
  text-decoration: none !important;
  color: inherit;
}
.link-card:hover {
  border-color: var(--accent);
  background: var(--bg-secondary);
}

.link-card__image {
  width: 56px;
  height: 56px;
  object-fit: cover;
  border-radius: 3px;
  flex-shrink: 0;
}

.link-card__body {
  display: flex;
  flex-direction: column;
  gap: 0.2rem;
  flex: 1;
  min-width: 0;
}

.link-card__domain {
  font-size: 0.6rem;
  color: var(--ink-faint);
  letter-spacing: 0.1em;
}

.link-card__title {
  font-family: var(--font-display);
  font-size: 1rem;
  color: var(--ink);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.link-card__desc {
  font-size: 0.82rem;
  color: var(--ink-muted);
  line-height: 1.4;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.link-card__arrow {
  color: var(--accent);
  font-size: 0.9rem;
  flex-shrink: 0;
}
</style>
