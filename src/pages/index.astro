---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { PROJECTS } from '../data/projects';
import { SITE_CONFIG, url } from '../config';
import { getCollection } from 'astro:content';

// Show featured first, then rest
const featured = PROJECTS.filter(p => p.featured);
const rest = PROJECTS.filter(p => !p.featured);
const ordered = [...featured, ...rest];

// Latest 3 blog posts
const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const posts = allPosts
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);
---

<BaseLayout>

  <!-- ─── Hero ─────────────────────────────────────────── -->
  <section class="hero section container">
    <div class="hero__top stagger">
      <p class="label hero__eyebrow">Portfolio — {new Date().getFullYear()}</p>

      <h1 class="hero__title">
        Ambiguity<br/>
        <em>as a Resource</em><br/>
        for Design
      </h1>

      <div class="hero__desc-col">
        <p class="hero__desc">
          <br/>
          My world exists at the intersection of rigid logic and fluid motion.
        </p>
        <div class="hero__skills label">
          <span>Software Architecture</span>
          <span class="hero__dot" aria-hidden="true">◆</span>
          <span>Graphic Design</span>
          <span class="hero__dot" aria-hidden="true">◆</span>
          <span>Figure Skating</span>
        </div>
      </div>

    </div>

    <div class="hero__scroll label" aria-hidden="true">
      Scroll to explore ↓
    </div>
  </section>

  <!-- ─── Divider ───────────────────────────────────────── -->
  <div class="divider container">
    <span class="label divider__label">Selected Work</span>
    <div class="divider__line"></div>
    <span class="label divider__count">{ordered.length} projects</span>
  </div>

  <!-- ─── Project List ─────────────────────────────────── -->
  <section class="projects section" aria-label="Projects">
    {ordered.map((project, i) => (
      <ProjectCard project={project} index={i} />
    ))}
  </section>

  <!-- ─── Writing Divider ──────────────────────────────── -->
  {posts.length > 0 && (
    <div class="divider container">
      <span class="label divider__label">Writing</span>
      <div class="divider__line"></div>
      <a href={url('/blog')} class="label divider__count divider__all">All posts →</a>
    </div>
  )}

  <!-- ─── Blog Preview ─────────────────────────────────── -->
  {posts.length > 0 && (
    <section class="blog-preview section container" aria-label="Recent writing">
      {posts.map((post, i) => (
        <a
          href={url(`/blog/${post.slug}`)}
          class="blog-row"
          style={`animation-delay: ${i * 0.08}s`}
        >
          <span class="blog-row__date label">
            {post.data.date.toLocaleDateString('en', { year: 'numeric', month: 'short', day: 'numeric' })}
          </span>
          <span class="blog-row__title">{post.data.title}</span>
          <span class="blog-row__desc">{post.data.description}</span>
          <span class="blog-row__arrow label">→</span>
        </a>
      ))}
    </section>
  )}

  <!-- ─── About Strip ──────────────────────────────────── -->
  <section class="about-strip container" id="about-preview">
    <div class="about-strip__inner">
      <div class="about-strip__text">
        <p class="label about-strip__eyebrow">About</p>
        <p class="about-strip__body">
          Hi, my name is Harris Su, a software designer from Taipei
          currently studying at National Cheng Kung University.
          By day, I engineer AI agents and tackle cybersecurity.
          By design, I craft intuitive apps and artistic graphics.
        </p>
        <a href={url('/about')} class="about-strip__cta label">
          Read more →
        </a>
      </div>
      <div class="about-strip__portrait">
        {SITE_CONFIG.PORTRAIT ? (
          <img src={url(SITE_CONFIG.PORTRAIT)} alt={SITE_CONFIG.TITLE} class="about-strip__portrait-img" />
        ) : (
          <div class="img-placeholder about-strip__portrait-placeholder"><span>Portrait</span></div>
        )}
      </div>
    </div>
  </section>

</BaseLayout>

<style>
/* ─── Hero ──────────────────────────────────────────────── */
.hero {
  padding-top: calc(4rem + var(--section-gap));
  display: flex;
  flex-direction: column;
  gap: 3rem;
}

.hero__top {
  display: grid;
  grid-template-columns: auto 1fr 1fr;
  gap: 3rem;
  align-items: start;
}

.hero__eyebrow {
  color: var(--ink-faint);
  writing-mode: vertical-rl;
  text-orientation: mixed;
  transform: rotate(180deg);
  align-self: stretch;
  padding-top: 0.5rem;
}

.hero__title {
  font-size: clamp(3rem, 6vw + 1rem, 7rem);
  letter-spacing: -0.04em;
  line-height: 1.0;
  font-weight: 400;
}

.hero__title em {
  font-style: italic;
  color: var(--accent);
}

.hero__desc-col {
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  gap: 1.5rem;
  padding-bottom: 0.5rem;
}

.hero__desc {
  color: var(--ink-muted);
  font-size: 1rem;
  line-height: 1.6;
  max-width: 38ch;
}

.hero__skills {
  display: flex;
  flex-wrap: wrap;
  gap: 0.5rem;
  align-items: center;
  color: var(--ink-faint);
  font-size: 0.65rem;
  letter-spacing: 0.12em;
}

.hero__dot { color: var(--accent); font-size: 0.4rem; }

.hero__scroll {
  color: var(--ink-faint);
  font-size: 0.65rem;
  letter-spacing: 0.12em;
  animation: fadeUp 1s 0.8s var(--ease) both;
}

/* ─── Divider ───────────────────────────────────────────── */
.divider {
  display: flex;
  align-items: center;
  gap: 1.5rem;
  margin-bottom: 0;
}

.divider__label, .divider__count {
  white-space: nowrap;
  color: var(--ink-faint);
  font-size: 0.68rem;
  letter-spacing: 0.12em;
}

.divider__all {
  color: var(--accent);
  transition: opacity 0.2s;
}
.divider__all:hover { opacity: 0.6; }

.divider__line {
  flex: 1;
  height: 1px;
  background: var(--border);
}

/* ─── Projects ──────────────────────────────────────────── */
.projects { padding-top: 2rem; }

/* ─── Blog Preview ──────────────────────────────────────── */
.blog-preview {
  padding-top: 2rem;
  display: flex;
  flex-direction: column;
}

.blog-row {
  display: grid;
  grid-template-columns: 120px 1fr 1fr auto;
  gap: 2rem;
  align-items: baseline;
  padding-block: 1.4rem;
  border-bottom: 1px solid var(--border);
  transition: opacity 0.2s;
  animation: fadeUp 0.6s var(--ease) both;
}
.blog-row:hover { opacity: 0.6; }

.blog-row__date {
  color: var(--ink-faint);
  font-size: 0.65rem;
}

.blog-row__title {
  font-family: var(--font-display);
  font-size: 1.1rem;
  color: var(--ink);
}

.blog-row__desc {
  color: var(--ink-muted);
  font-size: 0.9rem;
  line-height: 1.4;
}

.blog-row__arrow {
  color: var(--accent);
  font-size: 0.8rem;
}

/* ─── About Strip ───────────────────────────────────────── */
.about-strip {
  padding-block: var(--section-gap);
}

.about-strip__inner {
  display: grid;
  grid-template-columns: 1fr 380px;
  gap: 4rem;
  align-items: center;
  border: 1px solid var(--border);
  padding: 3rem;
}

.about-strip__eyebrow {
  color: var(--ink-faint);
  margin-bottom: 1rem;
}

.about-strip__body {
  font-size: clamp(1rem, 1.5vw, 1.25rem);
  line-height: 1.65;
  color: var(--ink-muted);
  max-width: 48ch;
  margin-bottom: 1.5rem;
}

.about-strip__cta {
  font-size: 0.72rem;
  letter-spacing: 0.12em;
  color: var(--accent);
  transition: opacity 0.2s;
}
.about-strip__cta:hover { opacity: 0.6; }

.about-strip__portrait {
  aspect-ratio: 3/4;
  width: 100%;
  overflow: hidden;
}

.about-strip__portrait-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}

.about-strip__portrait-placeholder {
  width: 100%;
  height: 100%;
}

@media (max-width: 900px) {
  .hero__top {
    grid-template-columns: 1fr;
  }
  .hero__eyebrow {
    writing-mode: horizontal-tb;
    transform: none;
  }
  .about-strip__inner {
    grid-template-columns: 1fr;
  }
  .about-strip__portrait {
    aspect-ratio: 16/9;
  }
  .blog-row {
    grid-template-columns: 1fr;
    gap: 0.4rem;
  }
  .blog-row__arrow { display: none; }
}
</style>
