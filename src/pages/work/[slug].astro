---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { url } from '../../config';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map((p) => ({
    params: { slug: p.slug },
    props: { project: p },
  }));
}

const { project } = Astro.props;
const { data: p, slug } = project;
const { Content } = await project.render();

// Adjacent projects for prev/next (sorted by order)
const allProjects = (await getCollection('projects'))
  .sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99));
const idx = allProjects.findIndex(p => p.slug === slug);
const prev = allProjects[idx - 1] ?? null;
const next = allProjects[idx + 1] ?? null;
---

<BaseLayout title={p.title} description={p.description}>

  <article class="project-page section container">

    <!-- ─── Back ─────────────────────────────────────────── -->
    <a href={url('/')} class="project-back label">← All Work</a>

    <!-- ─── Header ──────────────────────────────────────── -->
    <header class="project-header stagger">
      <div class="project-header__meta">
        <span class="label project-header__category">{p.category}</span>
        <span class="label project-header__year">{p.year}</span>
      </div>
      <h1 class="project-header__title">
        {p.title}
        {p.subtitle && (
          <em class="project-header__subtitle"> — {p.subtitle}</em>
        )}
      </h1>
      <p class="project-header__desc">{p.description}</p>

      <div class="project-header__tags">
        {p.tags.map(tag => (
          <span class="project-tag label">{tag}</span>
        ))}
      </div>

      {(p.link || p.github) && (
        <div class="project-header__links">
          {p.link && (
            <a href={p.link} class="project-link label" target="_blank" rel="noopener">
              Live Project ↗
            </a>
          )}
          {p.github && (
            <a href={p.github} class="project-link label" target="_blank" rel="noopener">
              GitHub ↗
            </a>
          )}
        </div>
      )}
    </header>

    <!-- ─── Cover Image ──────────────────────────────────── -->
    <div class="project-cover">
      {p.coverImage ? (
        <img
          src={url(p.coverImage)}
          alt={`${p.title} cover`}
          class="project-cover__img"
        />
      ) : (
        <div class="project-cover__placeholder img-placeholder">
          <span>{p.title}</span>
        </div>
      )}
    </div>

    <!-- ─── Article body ─────────────────────────────────── -->
    <div class="project-body prose">
      <Content />
    </div>

    <!-- ─── Videos ───────────────────────────────────────── -->
    {p.videos && p.videos.length > 0 && (
      <section class="project-videos" aria-label="Project videos">
        {p.videos.map((v) => (
          <figure class="project-video">
            <video
              src={url(v.src)}
              poster={v.poster ? url(v.poster) : undefined}
              controls
              preload="metadata"
              playsinline
            ></video>
            {v.caption && <figcaption class="project-video__caption label">{v.caption}</figcaption>}
          </figure>
        ))}
      </section>
    )}

    <!-- ─── Gallery ──────────────────────────────────────── -->
    {p.images && p.images.length > 0 && (
      <section class="project-gallery" aria-label="Project images">
        {p.images.map((img, i) => (
          <div class="project-gallery__item">
            {img ? (
              <img src={url(img)} alt={`${p.title} image ${i + 1}`} loading="lazy" />
            ) : (
              <div class="img-placeholder" style="aspect-ratio:16/9">
                <span>Image {i + 1}</span>
              </div>
            )}
          </div>
        ))}
      </section>
    )}

    <!-- ─── Navigation ───────────────────────────────────── -->
    <nav class="project-nav" aria-label="Project navigation">
      {prev ? (
        <a href={url(`/work/${prev.slug}`)} class="project-nav__item project-nav__item--prev">
          <span class="label project-nav__direction">← Previous</span>
          <span class="project-nav__name">{prev.data.title}</span>
        </a>
      ) : <span />}

      {next ? (
        <a href={url(`/work/${next.slug}`)} class="project-nav__item project-nav__item--next">
          <span class="label project-nav__direction">Next →</span>
          <span class="project-nav__name">{next.data.title}</span>
        </a>
      ) : <span />}
    </nav>

  </article>

</BaseLayout>

<style>
.project-page {
  padding-top: calc(4rem + 3rem);
  max-width: 860px;
}

.project-back {
  display: inline-block;
  font-size: 0.72rem;
  letter-spacing: 0.10em;
  color: var(--ink-muted);
  margin-bottom: 2.5rem;
  transition: color 0.2s;
}
.project-back:hover { color: var(--ink); }

.project-header {
  margin-bottom: 3rem;
}

.project-header__meta {
  display: flex;
  gap: 1rem;
  margin-bottom: 1rem;
}

.project-header__category {
  color: var(--accent);
  font-size: 0.68rem;
}

.project-header__year {
  color: var(--ink-faint);
  font-size: 0.68rem;
}

.project-header__title {
  font-size: clamp(2.5rem, 5vw, 5rem);
  letter-spacing: -0.03em;
  margin-bottom: 1.5rem;
  line-height: 1.05;
}

.project-header__subtitle {
  font-style: italic;
  opacity: 0.5;
}

.project-header__desc {
  color: var(--ink-muted);
  font-size: 1.05rem;
  line-height: 1.75;
  max-width: 60ch;
  margin-bottom: 1.5rem;
}

.project-header__tags {
  display: flex;
  flex-wrap: wrap;
  gap: 0.4rem;
  margin-bottom: 1.5rem;
}

.project-tag {
  font-size: 0.62rem;
  letter-spacing: 0.10em;
  color: var(--ink-faint);
  border: 1px solid var(--border-strong);
  padding: 0.15rem 0.5rem;
  border-radius: 2px;
}

.project-header__links {
  display: flex;
  gap: 2rem;
}

.project-link {
  font-size: 0.72rem;
  letter-spacing: 0.10em;
  color: var(--accent);
  transition: opacity 0.2s;
}
.project-link:hover { opacity: 0.6; }

/* Cover */
.project-cover {
  margin-bottom: 2rem;
  overflow: hidden;
  border-radius: 2px;
}

.project-cover__img {
  width: 100%;
  height: auto;
  display: block;
}

.project-cover__placeholder {
  aspect-ratio: 16/9;
}

/* ─── Article prose ──────────────────────────────────────── */
.project-body {
  margin-bottom: 3rem;
}

.prose {
  color: var(--ink);
  font-size: 1.7rem;
  line-height: 1.8;
  max-width: 65ch;
  border-top: 1px solid var(--border);
  padding-top: 2.5rem;
}

.prose :global(p) { margin-bottom: 1.4em; }
.prose :global(h2) {
  font-family: var(--font-display);
  font-size: 1.8rem;
  color: var(--ink);
  letter-spacing: -0.02em;
  margin-top: 2.5em;
  margin-bottom: 0.7em;
}
.prose :global(h3) {
  font-family: var(--font-display);
  font-size: 1.3rem;
  color: var(--ink);
  margin-top: 2em;
  margin-bottom: 0.5em;
}
.prose :global(ul), .prose :global(ol) {
  padding-left: 1.5rem;
  margin-bottom: 1.4em;
}
.prose :global(li) { margin-bottom: 0.4em; }
.prose :global(a) {
  color: var(--accent);
  text-decoration: underline;
  text-underline-offset: 3px;
}
.prose :global(blockquote) {
  border-left: 3px solid var(--accent);
  padding-left: 1.2rem;
  color: var(--ink-faint);
  font-style: italic;
  margin-block: 1.5em;
}
.prose :global(code) {
  font-family: var(--font-mono);
  font-size: 0.88em;
  background: var(--bg-secondary);
  padding: 0.1em 0.35em;
  border-radius: 3px;
}
.prose :global(pre) {
  background: var(--bg-secondary);
  padding: 1.2rem 1.5rem;
  border-radius: 4px;
  overflow-x: auto;
  margin-block: 1.5em;
}
.prose :global(pre code) { background: none; padding: 0; }
.prose :global(hr) {
  border: none;
  border-top: 1px solid var(--border);
  margin-block: 2.5em;
}

/* Videos */
.project-videos {
  display: flex;
  flex-direction: column;
  gap: 1.5rem;
  margin-bottom: 2.5rem;
}
.project-video {
  margin: 0;
  overflow: hidden;
  border-radius: 2px;
  background: var(--bg-secondary);
}
.project-video video {
  width: 100%;
  height: auto;
  display: block;
}
.project-video__caption {
  margin-top: 0.5rem;
  color: var(--ink-faint);
  font-size: 0.65rem;
}

/* Gallery */
.project-gallery {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 1rem;
  margin-bottom: 4rem;
}

.project-gallery__item { overflow: hidden; border-radius: 2px; }
.project-gallery__item img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.5s var(--ease);
}
.project-gallery__item:hover img { transform: scale(1.04); }

/* Nav */
.project-nav {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 2rem;
  padding-top: 3rem;
  border-top: 1px solid var(--border);
}

.project-nav__item {
  display: flex;
  flex-direction: column;
  gap: 0.4rem;
  transition: opacity 0.2s;
}
.project-nav__item:hover { opacity: 0.6; }

.project-nav__item--next {
  text-align: right;
}

.project-nav__direction {
  font-size: 0.68rem;
  letter-spacing: 0.10em;
  color: var(--ink-faint);
}

.project-nav__name {
  font-family: var(--font-display);
  font-size: 1.1rem;
}

@media (max-width: 600px) {
  .project-gallery { grid-template-columns: 1fr; }
}
</style>
