---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { url } from '../../config';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const posts = allPosts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<BaseLayout title="Writing" description="Essays and notes by Harris Su.">

  <div class="blog-index section container">

    <header class="blog-header stagger">
      <p class="label blog-header__eyebrow">Writing</p>
      <h1 class="blog-header__title">Notes &amp; Essays</h1>
    </header>

    <div class="blog-list">
      {posts.map((post, i) => (
        <a
          href={url(`/blog/${post.slug}`)}
          class="blog-row"
          style={`animation-delay: ${i * 0.06}s`}
        >
          <span class="blog-row__date label">
            {post.data.date.toLocaleDateString('en', { year: 'numeric', month: 'short', day: 'numeric' })}
          </span>
          <span class="blog-row__title">{post.data.title}</span>
          <span class="blog-row__desc">{post.data.description}</span>
          <div class="blog-row__tags">
            {post.data.tags.map(tag => (
              <span class="blog-row__tag label">{tag}</span>
            ))}
          </div>
          <span class="blog-row__arrow label">→</span>
        </a>
      ))}

      {posts.length === 0 && (
        <p class="blog-empty label">No posts yet.</p>
      )}
    </div>

  </div>

</BaseLayout>

<style>
.blog-index {
  padding-top: calc(4rem + var(--section-gap));
}

.blog-header {
  margin-bottom: 4rem;
}

.blog-header__eyebrow {
  color: var(--ink-faint);
  margin-bottom: 1rem;
}

.blog-header__title {
  font-size: clamp(3rem, 6vw, 7rem);
  letter-spacing: -0.04em;
  line-height: 1.0;
}

.blog-list {
  display: flex;
  flex-direction: column;
}

.blog-row {
  display: grid;
  grid-template-columns: 140px 1fr 1fr auto auto;
  gap: 2rem;
  align-items: baseline;
  padding-block: 1.5rem;
  border-bottom: 1px solid var(--border);
  transition: opacity 0.2s;
  animation: fadeUp 0.6s var(--ease) both;
}
.blog-row:hover { opacity: 0.6; }

.blog-row__date {
  color: var(--ink-faint);
  font-size: 0.65rem;
}

.blog-row__title {
  font-family: var(--font-display);
  font-size: 1.2rem;
  color: var(--ink);
}

.blog-row__desc {
  color: var(--ink-muted);
  font-size: 0.9rem;
  line-height: 1.4;
}

.blog-row__tags {
  display: flex;
  gap: 0.4rem;
  flex-wrap: wrap;
}

.blog-row__tag {
  font-size: 0.6rem;
  color: var(--ink-faint);
  border: 1px solid var(--border-strong);
  padding: 0.1rem 0.4rem;
  border-radius: 2px;
}

.blog-row__arrow {
  color: var(--accent);
  font-size: 0.8rem;
}

.blog-empty {
  color: var(--ink-faint);
  padding-block: 3rem;
}

@media (max-width: 800px) {
  .blog-row {
    grid-template-columns: 1fr;
    gap: 0.4rem;
  }
  .blog-row__arrow { display: none; }
}
</style>
